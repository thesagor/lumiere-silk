<section class="packaging-section section-pad" aria-label="Packaging experience">
  <div class="container">
    <div class="packaging-grid">

      <div class="packaging-text fade-in">
        {%- if section.settings.label != blank -%}
          <p class="text-label">{{ section.settings.label | escape }}</p>
        {%- endif -%}
        <h2 class="packaging-title heading-serif">{{ section.settings.heading }}</h2>
        <p class="packaging-body">{{ section.settings.body }}</p>
        {%- if section.settings.tagline != blank -%}
          <p class="packaging-tagline">{{ section.settings.tagline | escape }}</p>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="packaging-bullets">
            {%- for block in section.blocks -%}
              {%- if block.type == 'bullet' and block.settings.text != blank -%}
                <li class="packaging-bullet-item" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="packaging-image fade-in">
        {%- if section.settings.image != blank -%}
          {%- assign packaging_alt = section.settings.heading | escape -%}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              sizes: '(max-width: 768px) 100vw, 50vw',
              alt: packaging_alt
          }}
        {%- else -%}
          <img
            src="{{ 'lumiere-gift-packaging.jpg' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
          >
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumiere Packaging",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "The Experience"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "The Art of Gifting"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Every detail matters — from the softness of the silk to the presentation of the final box. Our packaging is designed to feel refined, graceful, and ready to gift, creating a memorable unboxing experience that reflects the beauty of the brand."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Refined packaging · Thoughtful details · Timeless impression"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Elegantly boxed, ribbon-tied"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lumiere Packaging",
      "settings": {
        "label": "The Experience",
        "heading": "The Art of Gifting",
        "body": "Every detail matters - from the softness of the silk to the presentation of the final box. Our packaging is designed to feel refined, graceful, and ready to gift, creating a memorable unboxing experience that reflects the beauty of the brand.",
        "tagline": "Refined packaging · Thoughtful details · Timeless impression"
      },
      "blocks": [
        {
          "type": "bullet",
          "settings": { "text": "Elegantly boxed, ribbon-tied" }
        },
        {
          "type": "bullet",
          "settings": { "text": "Ready to gift — no wrapping needed" }
        },
        {
          "type": "bullet",
          "settings": { "text": "Presented with a Lumière Silk card" }
        }
      ]
    }
  ]
}
{% endschema %}
