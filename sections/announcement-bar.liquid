{%- if section.settings.show_announcement -%}
  {%- assign messages = '' -%}
  {%- if section.settings.announcement_text != blank -%}
    {%- assign messages = messages | append: section.settings.announcement_text -%}
  {%- endif -%}
  {%- if section.settings.announcement_text_2 != blank -%}
    {%- if messages != '' -%}{%- assign messages = messages | append: ' · ' -%}{%- endif -%}
    {%- assign messages = messages | append: section.settings.announcement_text_2 -%}
  {%- endif -%}
  {%- if section.settings.announcement_text_3 != blank -%}
    {%- if messages != '' -%}{%- assign messages = messages | append: ' · ' -%}{%- endif -%}
    {%- assign messages = messages | append: section.settings.announcement_text_3 -%}
  {%- endif -%}

  <div class="announcement-bar" role="complementary" aria-label="Announcement">
    {%- if section.settings.announcement_link != blank -%}
      <a href="{{ section.settings.announcement_link }}" class="announcement-bar__text">{{ messages | escape }}</a>
    {%- else -%}
      <span class="announcement-bar__text">{{ messages | escape }}</span>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Message 1",
      "default": "Complimentary shipping on Canadian orders over $75"
    },
    {
      "type": "text",
      "id": "announcement_text_2",
      "label": "Message 2 (optional)",
      "default": "Gift-ready packaging on every order"
    },
    {
      "type": "text",
      "id": "announcement_text_3",
      "label": "Message 3 (optional)"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Link (optional)"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
