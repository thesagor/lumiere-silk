{% style %}
  .ls-mantra{background:var(--ls-ivory,#faf6ef);padding:88px 32px;text-align:center;}
  .ls-mantra__inner{max-width:920px;margin:0 auto;}
  .ls-mantra__eyebrow{display:inline-flex;align-items:center;gap:14px;margin-bottom:24px;}
  .ls-mantra__eyebrow .line{width:24px;height:1px;background:var(--ls-gold,#b89968);}
  .ls-mantra__eyebrow span:nth-child(2){font-family:var(--ls-sans,'Inter',sans-serif);font-size:10px;letter-spacing:0.32em;text-transform:uppercase;color:var(--ls-gold,#b89968);font-weight:400;}
  .ls-mantra__text{font-family:var(--ls-serif,'Cormorant Garamond',Georgia,serif);font-style:italic;font-size:clamp(24px,3.4vw,42px);line-height:1.3;font-weight:300;color:var(--ls-ink,#3d342a);letter-spacing:-0.005em;}
{% endstyle %}

<section class="ls-mantra">
  <div class="ls-mantra__inner">
    {%- if section.settings.eyebrow != blank -%}
      <div class="ls-mantra__eyebrow">
        <span class="line"></span>
        <span>{{ section.settings.eyebrow }}</span>
        <span class="line"></span>
      </div>
    {%- endif -%}
    <p class="ls-mantra__text">{{ section.settings.text }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Mantra Strip",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Lumière Promise" },
    { "type": "richtext", "id": "text", "label": "Mantra text", "default": "<p>More than a scarf — a refined gifting experience.</p>" }
  ],
  "presets": [{ "name": "Mantra Strip" }]
}
{% endschema %}
