{% style %}
  .ls-news{background:var(--ls-cream,#f3ebdd);padding:90px 0;}
  .ls-news__container{max-width:1440px;margin:0 auto;padding:0 40px;text-align:center;}
  .ls-news__inner{max-width:540px;margin:0 auto;}
  .ls-news__eyebrow{display:inline-block;font-family:var(--ls-sans,'Inter',sans-serif);font-size:10px;letter-spacing:0.32em;text-transform:uppercase;color:var(--ls-gold,#b89968);font-weight:400;}
  .ls-news__h{font-family:var(--ls-serif,'Cormorant Garamond',Georgia,serif);font-weight:400;font-size:clamp(26px,3.4vw,42px);line-height:1.1;color:var(--ls-ink,#3d342a);margin-top:18px;margin-bottom:14px;}
  .ls-news__p{font-family:var(--ls-sans,'Inter',sans-serif);font-size:13px;line-height:1.85;color:var(--ls-muted,#8b7d6b);font-weight:300;}
  .ls-news__form{margin-top:32px;display:flex;border-bottom:1px solid var(--ls-ink,#3d342a);}
  .ls-news__form input{flex:1;font-family:var(--ls-sans,'Inter',sans-serif);font-size:13px;padding:14px 4px;background:transparent;border:none;color:var(--ls-ink,#3d342a);outline:none;font-weight:300;}
  .ls-news__form button{font-family:var(--ls-sans,'Inter',sans-serif);font-size:11px;letter-spacing:0.24em;text-transform:uppercase;color:var(--ls-ink,#3d342a);background:transparent;border:none;padding:14px 0;cursor:pointer;font-weight:400;}
  .ls-news__success{margin-top:32px;font-family:var(--ls-serif,'Cormorant Garamond',Georgia,serif);font-style:italic;font-size:18px;color:var(--ls-gold,#b89968);}
  @media (max-width:768px){
    .ls-news__container{padding:0 24px;}
  }
{% endstyle %}

<section class="ls-news">
  <div class="ls-news__container">
    <div class="ls-news__inner">
      {%- if section.settings.eyebrow != blank -%}<span class="ls-news__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h3 class="ls-news__h">{{ section.settings.heading }}</h3>{%- endif -%}
      {%- if section.settings.body != blank -%}<p class="ls-news__p">{{ section.settings.body }}</p>{%- endif -%}

      {%- form 'customer', class: 'ls-news__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | default: 'Your email address' }}" required>
        <button type="submit">{{ section.settings.button_label | default: 'Subscribe' }} →</button>
        {%- if form.posted_successfully? -%}
          <p class="ls-news__success">Thank you — welcome.</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Circle",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay Close" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Lumière Circle" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Receive new arrivals, gifting guides, and quiet inspiration in your inbox." },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter Circle" }]
}
{% endschema %}
