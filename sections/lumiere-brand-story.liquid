<section class="brand-story-section section-pad" aria-label="Brand story">
  <div class="container">
    <div class="brand-story-inner fade-in">
      {%- if section.settings.label != blank -%}
        <p class="text-label">{{ section.settings.label | escape }}</p>
      {%- endif -%}
      <div class="brand-story-divider"></div>
      <h2 class="brand-story-title heading-serif">{{ section.settings.heading }}</h2>
      <p class="brand-story-body">{{ section.settings.body }}</p>
      <div class="brand-story-actions">
        {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
          <a href="{{ section.settings.button_url }}" class="btn btn-outline-light">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank and section.settings.button_2_url != blank -%}
          <a href="{{ section.settings.button_2_url }}" class="btn btn-ghost-light">
            {{ section.settings.button_2_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumiere Brand Story",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Our Philosophy"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Designed in Canada, inspired by timeless elegance."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Each piece is carefully selected to offer a soft, refined, and thoughtful gifting experience."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button 1 label",
      "default": "Shop Gift Sets"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button 1 URL"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 label (optional)",
      "default": "Explore Scarves"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Button 2 URL (optional)"
    }
  ],
  "presets": [
    {
      "name": "Lumiere Brand Story",
      "settings": {
        "label": "Our Philosophy",
        "heading": "Designed in Canada,<br><em>inspired by timeless elegance.</em>",
        "body": "Each piece is carefully selected to offer a soft, refined, and thoughtful gifting experience.",
        "button_label": "Shop Gift Sets",
        "button_2_label": "Explore Scarves"
      }
    }
  ]
}
{% endschema %}
