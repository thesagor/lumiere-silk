{% style %}
  .ls-gspot { background: var(--ls-cream, #f3ebdd); padding: 100px 0; }
  .ls-gspot__grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .ls-gspot__img {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--ls-ivory, #faf6ef);
  }
  .ls-gspot__img img { width: 100%; height: 100%; object-fit: cover; }
  .ls-gspot__placeholder { width: 100%; height: 100%; background: var(--ls-ivory, #faf6ef); }
  .ls-gspot__eyebrow {
    display: block;
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 10px;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--ls-gold, #b89968);
    font-weight: 400;
    margin-bottom: 20px;
  }
  .ls-gspot__title {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-weight: 300;
    font-size: clamp(36px, 4.5vw, 64px);
    line-height: 1.04;
    color: var(--ls-ink, #3d342a);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .ls-gspot__title em { font-style: italic; }
  .ls-gspot__subtitle {
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ls-muted, #8b7d6b);
    font-weight: 400;
    margin-bottom: 28px;
  }
  .ls-gspot__price {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: 48px;
    color: var(--ls-ink, #3d342a);
    font-weight: 300;
    line-height: 1;
    margin-bottom: 32px;
  }
  .ls-gspot__features {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    border-top: 1px solid var(--ls-line, #e6dcc8);
  }
  .ls-gspot__features li {
    display: flex;
    gap: 16px;
    align-items: center;
    padding: 15px 0;
    border-bottom: 1px solid var(--ls-line, #e6dcc8);
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 13px;
    color: var(--ls-ink, #3d342a);
    font-weight: 300;
    line-height: 1.6;
  }
  .ls-gspot__dash {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ls-gold, #b89968);
    flex-shrink: 0;
  }
  .ls-gspot__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ls-ink, #3d342a);
    text-decoration: none;
    border: 1px solid var(--ls-ink, #3d342a);
    padding: 16px 36px;
    font-weight: 400;
    transition: background 0.35s, color 0.35s;
  }
  .ls-gspot__btn:hover { background: var(--ls-ink, #3d342a); color: #faf6ef; }

  @media (max-width: 1024px) {
    .ls-gspot__grid { padding: 0 32px; gap: 56px; }
  }
  @media (max-width: 768px) {
    .ls-gspot { padding: 72px 0; }
    .ls-gspot__grid { grid-template-columns: 1fr; padding: 0 24px; gap: 40px; }
    .ls-gspot__img { aspect-ratio: 4 / 3; }
    .ls-gspot__price { font-size: 40px; }
  }
{% endstyle %}

<section class="ls-gspot">
  <div class="ls-gspot__grid">

    <!-- Image -->
    <div class="ls-gspot__img">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1000 }}"
          alt="{{ section.settings.title | escape }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="ls-gspot__placeholder"></div>
      {%- endif -%}
    </div>

    <!-- Copy -->
    <div>
      <span class="ls-gspot__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="ls-gspot__title">{{ section.settings.title }}</h2>
      <p class="ls-gspot__subtitle">{{ section.settings.subtitle }}</p>
      <p class="ls-gspot__price">{{ section.settings.price }}</p>

      {%- if section.blocks.size > 0 -%}
        <ul class="ls-gspot__features">
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}>
              <span class="ls-gspot__dash">—</span>
              {{ block.settings.text }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        <a class="ls-gspot__btn" href="{{ section.settings.button_url }}">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Gift Set Spotlight",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image",    "label": "Product image" },
    { "type": "text",         "id": "eyebrow",  "label": "Eyebrow",            "default": "The Signature Gift" },
    { "type": "richtext",     "id": "title",    "label": "Title",               "default": "<p>Signature<br><em>Gift Set</em></p>" },
    { "type": "text",         "id": "subtitle", "label": "Composition line",    "default": "Silk Scarf + Brooch + Luxury Gift Box" },
    { "type": "text",         "id": "price",    "label": "Price",               "default": "$169" },
    { "type": "text",         "id": "button_label", "label": "Button label",    "default": "Shop Gift Sets" },
    { "type": "url",          "id": "button_url",   "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature line",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "100% Mulberry Silk scarf, hand-rolled edges" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Gift Set Spotlight",
      "blocks": [
        { "type": "feature", "settings": { "text": "100% Mulberry Silk scarf, hand-rolled edges" } },
        { "type": "feature", "settings": { "text": "Signature Lumière brooch, gift-ready" } },
        { "type": "feature", "settings": { "text": "Signature gift box, satin-ribbon tied" } },
        { "type": "feature", "settings": { "text": "Arrives ready to give — no extra wrapping needed" } }
      ]
    }
  ]
}
{% endschema %}
