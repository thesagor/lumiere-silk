{%- liquid
  assign linked_collection = collections[section.settings.collection]
  assign cta_url = section.settings.button_url
  if cta_url == blank and linked_collection != blank and linked_collection.products_count > 0
    assign cta_url = linked_collection.url
  endif
  assign max_products = section.settings.products_limit | default: 3
-%}

<section class="gift-sets-section section-pad" aria-label="Gift sets">
  <div class="container">
    <div class="gift-sets-grid">

      <div class="gift-sets-image fade-in">
        {%- if section.settings.image != blank -%}
          {%- assign gift_sets_alt = section.settings.heading | escape -%}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              sizes: '(max-width: 768px) 100vw, 50vw',
              alt: gift_sets_alt
          }}
        {%- else -%}
          <img
            src="{{ 'lumiere-gift-sets.jpg' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
          >
        {%- endif -%}
      </div>

      <div class="gift-sets-text fade-in">
        {%- if section.settings.label != blank -%}
          <p class="text-label">{{ section.settings.label | escape }}</p>
        {%- endif -%}
        <h2 class="gift-sets-title heading-serif">{{ section.settings.heading }}</h2>
        <p class="gift-sets-body">{{ section.settings.body }}</p>
        {%- if section.settings.tagline != blank -%}
          <p class="gift-sets-tagline">{{ section.settings.tagline | escape }}</p>
        {%- endif -%}

        {%- if linked_collection != blank and linked_collection.products_count > 0 -%}
          <div class="gift-sets-product-list">
            {%- for product in linked_collection.products limit: max_products -%}
              <a href="{{ product.url }}" class="gift-sets-product-item">
                <div class="gift-sets-product-thumb">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 100 | image_tag: loading: 'lazy', alt: product.title }}
                  {%- else -%}
                    <div class="gift-sets-product-thumb-placeholder"></div>
                  {%- endif -%}
                </div>
                <div class="gift-sets-product-info">
                  <span class="gift-sets-product-title">{{ product.title }}</span>
                  {%- if product.description != blank -%}
                    <span class="gift-sets-product-desc">{{ product.description | strip_html | truncate: 60 }}</span>
                  {%- endif -%}
                </div>
                <div class="gift-sets-product-price">
                  {{ product.price | money }}
                </div>
              </a>
            {%- endfor -%}

            {%- if section.settings.button_label != blank and cta_url != blank -%}
              <div class="gift-sets-product-cta">
                <a href="{{ cta_url }}" class="btn btn-primary">
                  {{ section.settings.button_label | escape }} &rarr;
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- elsif section.settings.button_label != blank and cta_url != blank -%}
          <a href="{{ cta_url }}" class="btn btn-primary">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumiere Gift Sets",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Gift Sets"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Gift-Ready Elegance"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "More than an accessory, Lumière Silk is designed to be a beautiful gifting experience. Explore scarf gift boxes and thoughtfully paired sets created for special moments, personal treats, and meaningful gestures."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Beautifully chosen. Elegantly presented."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Product collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Number of products to show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Gift Sets"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL (leave blank to use linked collection)"
    }
  ],
  "presets": [
    {
      "name": "Lumiere Gift Sets",
      "settings": {
        "label": "Gift Sets",
        "heading": "Gift-Ready Elegance",
        "body": "More than an accessory, Lumiere Silk is designed to be a beautiful gifting experience. Explore scarf gift boxes and thoughtfully paired sets created for special moments, personal treats, and meaningful gestures.",
        "tagline": "Beautifully chosen. Elegantly presented.",
        "button_label": "Shop Gift Sets",
        "products_limit": 3
      }
    }
  ]
}
{% endschema %}
