<section class="brand-intro-section section-pad" aria-label="Brand introduction">
  <div class="container">
    <div class="brand-intro-grid">

      <div class="brand-intro-text fade-in">
        {%- if section.settings.label != blank -%}
          <p class="text-label">{{ section.settings.label | escape }}</p>
        {%- endif -%}
        <h2 class="brand-intro-title heading-serif">{{ section.settings.heading }}</h2>
        <p class="brand-intro-body">{{ section.settings.body }}</p>
        {%- if section.blocks.size > 0 -%}
          <ul class="brand-intro-bullets">
            {%- for block in section.blocks -%}
              {%- if block.type == 'bullet' and block.settings.text != blank -%}
                <li class="brand-intro-bullet-item" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
          <a href="{{ section.settings.button_url }}" class="btn btn-outline" style="margin-top:2rem;">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="brand-intro-image-wrap fade-in">
        <div class="brand-intro-image">
          {%- if section.settings.image != blank -%}
            {%- assign brand_intro_alt = section.settings.heading | escape -%}
            {{
              section.settings.image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                sizes: '(max-width: 768px) 100vw, 50vw',
                alt: brand_intro_alt
            }}
          {%- else -%}
            <img
              src="{{ 'lumiere-brand-intro.jpg' | asset_url }}"
              alt="{{ section.settings.heading | escape }}"
              loading="lazy"
            >
          {%- endif -%}
        </div>
        <div class="brand-intro-image-border" aria-hidden="true"></div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumiere Brand Intro",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Our Philosophy"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Timeless Beauty, Thoughtfully Presented"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Lumière Silk is a premium accessories and gifting brand centered around elegance, softness, and refined details. From silk scarves to beautifully presented gift sets, each piece is chosen to offer a graceful and elevated experience for both personal use and meaningful gifting."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Ready-to-gift packaging — no extra wrapping needed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lumiere Brand Intro",
      "settings": {
        "label": "Why Customers Love Lumière Silk",
        "heading": "More than a scarf —<br><em>a refined gifting experience.</em>",
        "body": "Each Lumière Silk piece is created to feel intentional and refined — ready to give, beautifully presented, and made for the moments that matter.",
        "button_label": "Discover Our Story"
      },
      "blocks": [
        { "type": "bullet", "settings": { "text": "Ready-to-gift packaging — no extra wrapping needed" } },
        { "type": "bullet", "settings": { "text": "Elegant presentation that feels premium" } },
        { "type": "bullet", "settings": { "text": "A thoughtful gift for any occasion" } },
        { "type": "bullet", "settings": { "text": "Free shipping across Canada" } }
      ]
    }
  ]
}
{% endschema %}
