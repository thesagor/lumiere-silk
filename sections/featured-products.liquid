{%- if section.settings.label != blank or section.settings.heading != blank or section.blocks.size > 0 -%}
<div class="collection-section section-pad{% if section.settings.bg == 'cream' %} featured-products--cream{% endif %}">
  <div class="container">

    {%- if section.settings.label != blank or section.settings.heading != blank or section.settings.subtext != blank -%}
      <div class="collection-header">
        {%- if section.settings.label != blank -%}
          <p class="text-label">{{ section.settings.label | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="collection-title heading-serif">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="featured-products__subtext">{{ section.settings.subtext | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign col_class = 'featured-products--cols-' | append: section.settings.columns -%}
    <div class="collection-grid {{ col_class }}">
      {%- for block in section.blocks -%}
        {%- assign picked = block.settings.product -%}
        {%- if picked != blank -%}
          {%- render 'product-card', product: picked -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="featured-products__footer">
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn-outline">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% style %}
  .featured-products--cream { background: var(--color-cream, #f3ebdd); }
  .featured-products__subtext {
    font-size: 0.9375rem;
    color: var(--color-text-muted, #8b7d6b);
    line-height: 1.75;
    margin-top: 0.5rem;
    max-width: 520px;
  }
  .featured-products__footer {
    text-align: center;
    margin-top: 3rem;
  }
  .featured-products--cols-2 { grid-template-columns: repeat(2, 1fr) !important; }
  .featured-products--cols-3 { grid-template-columns: repeat(3, 1fr) !important; }
  .featured-products--cols-4 { grid-template-columns: repeat(4, 1fr) !important; }
  @media (max-width: 768px) {
    .featured-products--cols-3,
    .featured-products--cols-4 { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 480px) {
    .featured-products--cols-2,
    .featured-products--cols-3,
    .featured-products--cols-4 { grid-template-columns: 1fr !important; }
  }
{% endstyle %}
{%- endif -%}

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext (optional)"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Products per row",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "bg",
      "label": "Background",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "cream", "label": "Cream" }
      ],
      "default": "white"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}
