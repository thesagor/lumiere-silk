<section class="newsletter-section section-pad-sm" aria-label="Newsletter signup">
  <div class="container">
    <div class="newsletter-inner fade-in">
      <h2 class="newsletter-title heading-serif">{{ section.settings.heading }}</h2>
      <p class="newsletter-body">{{ section.settings.body }}</p>

      {%- form 'customer', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input
          class="newsletter-input"
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
          required
          aria-label="Email for newsletter"
          autocomplete="email"
        >
        <button type="submit" class="newsletter-submit">{{ section.settings.button_label | default: 'Subscribe' }}</button>
        {%- if form.posted_successfully? -%}
          <p style="width:100%; text-align:center; color:var(--color-gold); font-size:0.875rem; margin-top:0.75rem;">
            Thank you for joining us.
          </p>
        {%- endif -%}
      {%- endform -%}

      {%- if section.settings.note != blank -%}
        <p class="newsletter-note">{{ section.settings.note | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumiere Newsletter",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Lumière Circle"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Be the first to discover new arrivals, exclusive offers, and styling inspiration — delivered softly to your inbox."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note (below form)",
      "default": "We respect your privacy. Unsubscribe at any time."
    }
  ],
  "presets": [
    {
      "name": "Lumiere Newsletter",
      "settings": {
        "heading": "Join the Lumiere Circle",
        "body": "Be the first to discover new arrivals, exclusive offers, and styling inspiration - delivered softly to your inbox.",
        "placeholder": "Your email address",
        "button_label": "Subscribe",
        "note": "We respect your privacy. Unsubscribe at any time."
      }
    }
  ]
}
{% endschema %}
