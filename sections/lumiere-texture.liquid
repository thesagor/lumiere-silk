{% style %}
  .ls-texture{position:relative;height:85vh;min-height:560px;overflow:hidden;}
  .ls-texture__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
  .ls-texture__overlay{position:absolute;inset:0;background:linear-gradient(120deg,rgba(42,34,24,0.18) 0%,rgba(42,34,24,0) 60%);}
  .ls-texture__card{position:absolute;left:60px;top:50%;transform:translateY(-50%);max-width:380px;}
  .ls-texture__card-inner{display:inline-block;padding:22px 26px;background:rgba(250,246,239,0.88);backdrop-filter:blur(8px);border:1px solid rgba(184,153,104,0.25);}
  .ls-texture__eyebrow{display:inline-block;font-family:var(--ls-sans,'Inter',sans-serif);font-size:10px;letter-spacing:0.32em;text-transform:uppercase;color:var(--ls-gold,#b89968);font-weight:400;}
  .ls-texture__title{font-family:var(--ls-serif,'Cormorant Garamond',Georgia,serif);font-weight:300;font-size:clamp(26px,3.4vw,42px);line-height:1.1;margin-top:14px;font-style:italic;color:var(--ls-ink,#3d342a);}
  .ls-texture__body{font-family:var(--ls-sans,'Inter',sans-serif);font-size:13px;line-height:1.85;color:var(--ls-ink,#3d342a);opacity:0.75;margin-top:14px;font-weight:300;}
  .ls-texture__caption{position:absolute;right:48px;bottom:48px;color:rgba(250,246,239,0.85);text-align:right;}
  .ls-texture__caption p{font-family:var(--ls-sans,'Inter',sans-serif);font-size:10px;letter-spacing:0.32em;text-transform:uppercase;}
  @media (max-width:768px){
    .ls-texture__card{left:20px;right:20px;max-width:none;}
    .ls-texture__caption{right:20px;bottom:20px;}
  }
{% endstyle %}

<section class="ls-texture">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2400 | image_tag: alt: section.settings.heading | escape, class: 'ls-texture__img', sizes: '100vw', loading: 'lazy' }}
  {%- else -%}
    <img src="{{ 'lumiere-product-detail-4.png' | asset_url }}" alt="{{ section.settings.heading | escape }}" class="ls-texture__img" loading="lazy">
  {%- endif -%}
  <div class="ls-texture__overlay"></div>

  <div class="ls-texture__card">
    <div class="ls-texture__card-inner">
      {%- if section.settings.eyebrow != blank -%}<span class="ls-texture__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h3 class="ls-texture__title">{{ section.settings.heading }}</h3>{%- endif -%}
      {%- if section.settings.body != blank -%}<p class="ls-texture__body">{{ section.settings.body }}</p>{%- endif -%}
    </div>
  </div>

  {%- if section.settings.caption != blank -%}
    <div class="ls-texture__caption"><p>{{ section.settings.caption }}</p></div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Texture Section",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image (silk texture)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Material · Plate 01" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The hand of pure silk." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Soft, fluid, weightless — chosen for the way it falls, the way it holds light, and the way it feels close to the skin." },
    { "type": "text", "id": "caption", "label": "Caption (bottom right)", "default": "Detail / 100% Mulberry Silk" }
  ],
  "presets": [{ "name": "Texture Section" }]
}
{% endschema %}
