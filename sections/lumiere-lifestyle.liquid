{% style %}
  .ls-life{position:relative;height:90vh;min-height:640px;overflow:hidden;}
  .ls-life__img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 35%;}
  .ls-life__overlay{position:absolute;inset:0;background:linear-gradient(90deg,rgba(42,34,24,0) 50%,rgba(42,34,24,0.55) 100%);}
  .ls-life__col{position:absolute;right:0;top:0;bottom:0;width:50%;display:flex;align-items:center;padding:0 80px;}
  .ls-life__inner{max-width:460px;color:#faf6ef;}
  .ls-life__eyebrow{display:inline-block;font-family:var(--ls-sans,'Inter',sans-serif);font-size:10px;letter-spacing:0.32em;text-transform:uppercase;color:rgba(250,246,239,0.7);font-weight:400;}
  .ls-life__title{font-family:var(--ls-serif,'Cormorant Garamond',Georgia,serif);font-weight:300;font-size:clamp(36px,5vw,68px);line-height:1.06;color:#faf6ef;margin-top:22px;margin-bottom:24px;}
  .ls-life__title em{font-style:italic;}
  .ls-life__body{font-family:var(--ls-sans,'Inter',sans-serif);font-size:15px;line-height:1.85;color:rgba(250,246,239,0.78);margin-bottom:34px;font-weight:300;}
  .ls-life__btn{display:inline-flex;align-items:center;gap:10px;font-family:var(--ls-sans,'Inter',sans-serif);font-size:11px;letter-spacing:0.22em;text-transform:uppercase;padding:15px 32px;font-weight:400;transition:all 0.35s;border:1px solid rgba(250,246,239,0.5);color:#faf6ef;background:transparent;}
  .ls-life__btn:hover{background:rgba(250,246,239,0.08);}
  @media (max-width:900px){
    .ls-life__col{position:relative;width:100%;padding:64px 24px;background:rgba(42,34,24,0.55);}
    .ls-life{height:auto;min-height:0;}
    .ls-life__img{position:relative;height:60vh;}
    .ls-life__overlay{display:none;}
  }
{% endstyle %}

<section class="ls-life">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2400 | image_tag: alt: section.settings.heading | escape, class: 'ls-life__img', loading: 'lazy', sizes: '100vw' }}
  {%- else -%}
    <img src="{{ 'lumiere-lifestyle-1.jpg' | asset_url }}" alt="{{ section.settings.heading | escape }}" class="ls-life__img" loading="lazy">
  {%- endif -%}
  <div class="ls-life__overlay"></div>
  <div class="ls-life__col">
    <div class="ls-life__inner">
      {%- if section.settings.eyebrow != blank -%}<span class="ls-life__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="ls-life__title">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.body != blank -%}<p class="ls-life__body">{{ section.settings.body }}</p>{%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
        <a class="ls-life__btn" href="{{ section.settings.button_url }}">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lifestyle Moment",
  "tag": "div",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Lifestyle image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Plate 02 · Lifestyle" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Worn close,<br /><em>kept always.</em></p>" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "A Lumière Silk piece is the kind of thing she'll reach for on the days that matter — and the ordinary ones, too. Worn at the neck, tied at the wrist, draped at the shoulder." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Lifestyle" },
    { "type": "url", "id": "button_url", "label": "Button URL" }
  ],
  "presets": [{ "name": "Lifestyle Moment" }]
}
{% endschema %}
