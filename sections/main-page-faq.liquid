<div class="page-banner">
  <h1 class="page-banner-title heading-serif">Frequently Asked Questions</h1>
</div>

<div class="container">
  <div class="page-content">
    <div style="max-width:720px; margin:0 auto;">

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'faq_item' -%}
            <div class="faq-item" {{ block.shopify_attributes }}>
              <button class="faq-question" aria-expanded="false">
                {{ block.settings.question }}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div class="faq-answer" aria-hidden="true">
                <div class="faq-answer-inner">{{ block.settings.answer }}</div>
              </div>
            </div>
        {%- endcase -%}
      {%- else -%}

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">What material are your scarves made from?<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg></button>
          <div class="faq-answer"><div class="faq-answer-inner">All Lumière Silk scarves are crafted from 100% Mulberry Silk with a luxurious twill finish.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Where are your products designed?<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg></button>
          <div class="faq-answer"><div class="faq-answer-inner">Our collections are thoughtfully designed in Canada and crafted in China.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Do your scarves come in gift packaging?<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg></button>
          <div class="faq-answer"><div class="faq-answer-inner"><p>Our Gift Sets include a signature Lumière Silk gift box, ribbon presentation, and elegant brooch.</p><p>Scarf-only purchases are carefully packaged but do not include the gift box.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">How long does shipping take?<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg></button>
          <div class="faq-answer"><div class="faq-answer-inner"><p>We offer complimentary Canada-wide shipping on orders over CAD $75.</p><p>Most orders arrive within 2–5 business days.</p></div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Can I return my order?<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg></button>
          <div class="faq-answer"><div class="faq-answer-inner">Yes. Please review our <a href="{{ shop.refund_policy.url }}">Refund Policy</a> for full details.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">How can I contact Lumière Silk?<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/></svg></button>
          <div class="faq-answer"><div class="faq-answer-inner">You may contact us through our <a href="/pages/contact">Contact page</a> or by email at <a href="mailto:hello@lumieresilk.ca">hello@lumieresilk.ca</a>.</div></div>
        </div>

      {%- endfor -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ Page",
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page"
    }
  ]
}
{% endschema %}
