{% style %}
  /* ── Collection header ── */
  .ls-col__header {
    position: relative;
    padding: 120px 48px 88px;
    text-align: center;
    background: var(--ls-ivory, #faf6ef);
    overflow: hidden;
  }
  .ls-col__header-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.07;
    pointer-events: none;
  }
  .ls-col__header-inner { position: relative; z-index: 1; }
  .ls-col__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-bottom: 26px;
    color: var(--ls-muted, #8b7d6b);
  }
  .ls-col__eyebrow-line { width: 36px; height: 1px; background: var(--ls-line, #e6dcc8); }
  .ls-col__eyebrow-text {
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 10px;
    letter-spacing: 0.46em;
    text-transform: uppercase;
    font-weight: 400;
  }
  .ls-col__title {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-weight: 300;
    font-size: clamp(44px, 6.5vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.015em;
    color: var(--ls-ink, #3d342a);
    margin-bottom: 22px;
  }
  .ls-col__desc {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: clamp(15px, 1.6vw, 19px);
    color: var(--ls-muted, #8b7d6b);
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.65;
    font-weight: 300;
  }

  /* ── Toolbar ── */
  .ls-col__toolbar {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 48px;
    height: 48px;
    border-bottom: 1px solid var(--ls-line, #e6dcc8);
    background: var(--ls-ivory, #faf6ef);
  }
  .ls-col__sort-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .ls-col__sort-prefix {
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ls-muted, #8b7d6b);
    font-weight: 400;
    user-select: none;
  }
  .ls-col__sort-select {
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: transparent;
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ls-ink, #3d342a);
    cursor: pointer;
    padding-right: 18px;
    font-weight: 400;
    outline: none;
  }
  .ls-col__sort-caret {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--ls-muted, #8b7d6b);
  }

  /* ── Product grid container ── */
  .ls-col__body {
    background: var(--ls-ivory, #faf6ef);
    padding: 48px 16px 96px;
  }
  .ls-col__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 32px;
    max-width: 1440px;
    margin: 0 auto;
  }

  /* ── Product card ── */
  .ls-pc {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .ls-pc__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--ls-cream, #f3ebdd);
  }
  .ls-pc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }
  .ls-pc:hover .ls-pc__img { transform: scale(1.04); }
  .ls-pc__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ls-ink, #3d342a);
    background: rgba(250, 246, 239, 0.92);
    padding: 5px 10px;
    backdrop-filter: blur(4px);
    font-weight: 400;
  }
  .ls-pc__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.3;
  }
  .ls-pc__info {
    padding: 16px 0 22px;
    border-bottom: 1px solid var(--ls-line, #e6dcc8);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .ls-pc__name {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-size: 20px;
    font-weight: 400;
    color: var(--ls-ink, #3d342a);
    line-height: 1.2;
  }
  .ls-pc__price {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ls-muted, #8b7d6b);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ls-pc__price s {
    font-style: normal;
    font-size: 13px;
    margin-right: 5px;
    opacity: 0.55;
    text-decoration: line-through;
  }
  .ls-pc__name-group { display: flex; flex-direction: column; gap: 4px; }
  .ls-pc__subtitle {
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ls-muted, #8b7d6b);
    font-weight: 400;
  }

  /* ── Empty state ── */
  .ls-col__empty {
    text-align: center;
    padding: 100px 40px;
    background: var(--ls-ivory, #faf6ef);
  }
  .ls-col__empty-msg {
    font-family: var(--ls-serif, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    font-size: 22px;
    font-weight: 300;
    color: var(--ls-muted, #8b7d6b);
    margin-bottom: 28px;
  }
  .ls-col__empty-link {
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ls-ink, #3d342a);
    text-decoration: none;
    border-bottom: 1px solid var(--ls-ink, #3d342a);
    padding-bottom: 2px;
    transition: opacity 0.25s;
  }
  .ls-col__empty-link:hover { opacity: 0.55; }

  /* ── Pagination ── */
  .ls-col__pagination {
    text-align: center;
    padding: 48px 0 64px;
    background: var(--ls-ivory, #faf6ef);
    border-top: 1px solid var(--ls-line, #e6dcc8);
  }
  .ls-col__pagination .pagination {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ls-col__pagination .pagination a,
  .ls-col__pagination .pagination span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 8px;
    font-family: var(--ls-sans, 'Inter', sans-serif);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--ls-muted, #8b7d6b);
    text-decoration: none;
    transition: color 0.25s;
  }
  .ls-col__pagination .pagination a:hover { color: var(--ls-ink, #3d342a); }
  .ls-col__pagination .pagination .current {
    color: var(--ls-ink, #3d342a);
    border-bottom: 1px solid var(--ls-ink, #3d342a);
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .ls-col__header { padding: 96px 32px 72px; }
    .ls-col__toolbar { padding: 0 32px; }
    .ls-col__body { padding: 36px 12px 72px; }
    .ls-col__grid { grid-template-columns: repeat(2, 1fr); gap: 36px 24px; }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .ls-col__header { padding: 80px 24px 56px; }
    .ls-col__title { font-size: clamp(38px, 11vw, 60px); }
    .ls-col__desc { font-size: 15px; }
    .ls-col__toolbar { padding: 0 20px; height: 44px; }
    .ls-col__body { padding: 28px 16px 60px; }
    .ls-col__grid { grid-template-columns: repeat(2, 1fr); gap: 28px 16px; }
    .ls-pc__name { font-size: 17px; }
    .ls-pc__price { font-size: 15px; }
    .ls-pc__info { padding: 12px 0 18px; }
    .ls-pc__badge { font-size: 8px; padding: 4px 8px; }
  }

  /* ── Small phones ── */
  @media (max-width: 420px) {
    .ls-col__header { padding: 64px 20px 44px; }
    .ls-col__grid { grid-template-columns: 1fr; gap: 36px; }
    .ls-col__body { padding: 24px 20px 56px; }
  }
{% endstyle %}

<!-- Collection header -->
<header class="ls-col__header">
  {%- if collection.image -%}
    <img
      src="{{ collection.image | image_url: width: 2000 }}"
      alt=""
      class="ls-col__header-bg"
      loading="eager"
      aria-hidden="true"
    >
  {%- endif -%}
  <div class="ls-col__header-inner">
    <div class="ls-col__eyebrow">
      <span class="ls-col__eyebrow-line"></span>
      <span class="ls-col__eyebrow-text">Lumière Silk</span>
      <span class="ls-col__eyebrow-line"></span>
    </div>
    <h1 class="ls-col__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="ls-col__desc">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</header>

<!-- Minimal sort toolbar -->
<div class="ls-col__toolbar">
  <div class="ls-col__sort-wrap">
    <label class="ls-col__sort-prefix" for="ls-sort">Sort</label>
    <select
      class="ls-col__sort-select"
      id="ls-sort"
      aria-label="Sort products"
      onchange="window.location.href = '{{ collection.url }}?sort_by=' + encodeURIComponent(this.value)"
    >
      {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
      <option value="manual"            {% if sort_by == 'manual'            %}selected{% endif %}>Featured</option>
      <option value="price-ascending"   {% if sort_by == 'price-ascending'   %}selected{% endif %}>Price: Low–High</option>
      <option value="price-descending"  {% if sort_by == 'price-descending'  %}selected{% endif %}>Price: High–Low</option>
      <option value="title-ascending"   {% if sort_by == 'title-ascending'   %}selected{% endif %}>A–Z</option>
      <option value="created-descending"{% if sort_by == 'created-descending'%}selected{% endif %}>Newest</option>
      <option value="best-selling"      {% if sort_by == 'best-selling'      %}selected{% endif %}>Best Selling</option>
    </select>
    <svg class="ls-col__sort-caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
      <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</div>

<!-- Product grid -->
{%- assign excluded_products = section.settings.excluded_product_handles | downcase | split: ',' -%}

{%- paginate collection.products by 24 -%}

  {%- if collection.products_count > 0 -%}
    <div class="ls-col__body">
      <div class="ls-col__grid">
        {%- for product in collection.products -%}

          {%- assign is_excluded = false -%}
          {%- for ex in excluded_products -%}
            {%- if ex | strip == product.handle -%}
              {%- assign is_excluded = true -%}
            {%- endif -%}
          {%- endfor -%}
          {%- if is_excluded -%}{%- continue -%}{%- endif -%}

          <a class="ls-pc" href="{{ product.url }}">
            <div class="ls-pc__media">
              {%- if product.featured_image -%}
                <img
                  class="ls-pc__img"
                  src="{{ product.featured_image | image_url: width: 900 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="{% if forloop.index <= 6 %}eager{% else %}lazy{% endif %}"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'ls-pc__placeholder' }}
              {%- endif -%}

              {%- if product.available == false -%}
                <span class="ls-pc__badge">Sold Out</span>
              {%- elsif product.compare_at_price > product.price -%}
                <span class="ls-pc__badge">Sale</span>
              {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
                <span class="ls-pc__badge">New Arrival</span>
              {%- elsif product.tags contains 'bestseller' or product.tags contains 'Bestseller' -%}
                <span class="ls-pc__badge">Bestseller</span>
              {%- endif -%}
            </div>

            <div class="ls-pc__info">
              <div class="ls-pc__name-group">
                <span class="ls-pc__name">{{ product.title }}</span>
                {%- if section.settings.product_subtitle != blank -%}
                  <span class="ls-pc__subtitle">{{ section.settings.product_subtitle }}</span>
                {%- endif -%}
              </div>
              <span class="ls-pc__price">
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                {{ product.price | money }}
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="ls-col__pagination">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}

  {%- else -%}
    <div class="ls-col__empty">
      <p class="ls-col__empty-msg">Nothing here yet — check back soon.</p>
      <a class="ls-col__empty-link" href="{{ routes.all_products_collection_url }}">Browse All</a>
    </div>
  {%- endif -%}

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Product subtitle",
      "info": "Shown under every product name — e.g. \"100% Mulberry Silk · Hand-Rolled Edges\". Leave blank to hide.",
      "default": "100% Mulberry Silk · Hand-Rolled Edges"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "textarea",
      "id": "excluded_product_handles",
      "label": "Exclude products",
      "info": "Enter product handles separated by commas. Find a handle in Shopify Admin → Products → click a product → the URL slug after /products/. Example: signature-silk-scarf, petite-scarf-blue"
    }
  ]
}
{% endschema %}
