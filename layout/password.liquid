<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#faf8f5">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>{{ shop.name }} &ndash; Coming Soon</title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  {{ 'lumiere.css' | asset_url | stylesheet_tag }}

  <style>
    /* ── Password page base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: var(--color-ivory, #faf8f5);
      font-family: var(--font-body, 'Inter', sans-serif);
      color: var(--color-warm-black, #2a2218);
    }

    /* ── Full-screen layout ── */
    .pwd-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      position: relative;
      overflow: hidden;
      background: var(--color-ivory, #faf8f5);
    }

    /* Decorative background radial glow */
    .pwd-page::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 50% 0%, rgba(201,169,110,0.12) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 80% 80%, rgba(240,232,228,0.6) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── Header bar (top-right "Enter password" link) ── */
    .pwd-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 2rem;
      z-index: 10;
    }

    .pwd-header-logo {
      font-family: var(--font-heading, 'Cormorant Garamond', serif);
      font-size: 1.25rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      color: var(--color-warm-black, #2a2218);
      text-decoration: none;
      text-transform: uppercase;
    }

    .pwd-header-link {
      font-family: var(--font-body, 'Inter', sans-serif);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-gold, #c9a96e);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s ease, color 0.2s ease;
      cursor: pointer;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      padding: 0;
    }

    .pwd-header-link:hover {
      color: var(--color-warm-black, #2a2218);
      border-bottom-color: var(--color-gold, #c9a96e);
    }

    /* ── Main content ── */
    .pwd-main {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 2rem;
      max-width: 620px;
      width: 100%;
      animation: pwd-fadein 1s ease both;
    }

    @keyframes pwd-fadein {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .pwd-eyebrow {
      display: inline-block;
      font-family: var(--font-body, 'Inter', sans-serif);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-gold, #c9a96e);
      margin-bottom: 1.25rem;
    }

    .pwd-title {
      font-family: var(--font-heading, 'Cormorant Garamond', serif);
      font-size: clamp(2.8rem, 7vw, 4.5rem);
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: 0.02em;
      color: var(--color-warm-black, #2a2218);
      margin-bottom: 1.5rem;
    }

    .pwd-title em {
      font-style: italic;
      color: var(--color-gold, #c9a96e);
    }

    .pwd-divider {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
    }

    .pwd-divider-line {
      width: 48px;
      height: 1px;
      background: var(--color-gold, #c9a96e);
      opacity: 0.5;
    }

    .pwd-divider-diamond {
      font-size: 0.5rem;
      color: var(--color-gold, #c9a96e);
      opacity: 0.7;
    }

    .pwd-message {
      font-family: var(--font-body, 'Inter', sans-serif);
      font-size: 0.9rem;
      font-weight: 300;
      line-height: 1.75;
      color: var(--color-text-muted, #8a7d6f);
      margin-bottom: 2.5rem;
      max-width: 440px;
      margin-left: auto;
      margin-right: auto;
    }

    /* content_for_layout (main-password section) sits here */
    .pwd-content-wrap {
      margin-top: 0.5rem;
    }

    /* ── Footer note ── */
    .pwd-footer {
      position: fixed;
      bottom: 1.5rem;
      left: 0;
      right: 0;
      text-align: center;
      z-index: 10;
    }

    .pwd-footer p {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      color: var(--color-text-muted, #8a7d6f);
      text-transform: uppercase;
    }

    .pwd-footer a {
      color: var(--color-gold, #c9a96e);
      text-decoration: none;
    }

    /* ── Login Modal ── */
    .pwd-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(42,34,24,0.55);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 100;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .pwd-modal-overlay.is-open {
      display: flex;
      opacity: 1;
    }

    .pwd-modal {
      background: var(--color-ivory, #faf8f5);
      border: 1px solid var(--color-border, #e8e2d9);
      padding: 3rem 2.5rem;
      max-width: 420px;
      width: 90%;
      text-align: center;
      position: relative;
      transform: translateY(20px);
      transition: transform 0.35s ease;
      border-radius: 2px;
    }

    .pwd-modal-overlay.is-open .pwd-modal {
      transform: translateY(0);
    }

    .pwd-modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--color-text-muted, #8a7d6f);
      padding: 0.4rem;
      line-height: 1;
      transition: color 0.2s ease;
    }

    .pwd-modal-close:hover {
      color: var(--color-warm-black, #2a2218);
    }

    .pwd-modal-eyebrow {
      font-family: var(--font-body, 'Inter', sans-serif);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-gold, #c9a96e);
      margin-bottom: 0.75rem;
    }

    .pwd-modal-heading {
      font-family: var(--font-heading, 'Cormorant Garamond', serif);
      font-size: 1.85rem;
      font-weight: 400;
      color: var(--color-warm-black, #2a2218);
      margin-bottom: 0.5rem;
    }

    .pwd-modal-sub {
      font-size: 0.8rem;
      color: var(--color-text-muted, #8a7d6f);
      margin-bottom: 2rem;
      line-height: 1.6;
    }

    .pwd-modal-error {
      font-size: 0.8rem;
      color: #b94040;
      margin-bottom: 1rem;
      background: rgba(185,64,64,0.06);
      padding: 0.6rem 0.8rem;
      border-left: 2px solid #b94040;
    }

    .pwd-modal-input {
      width: 100%;
      padding: 0.9rem 1.1rem;
      font-family: var(--font-body, 'Inter', sans-serif);
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      background: var(--color-cream, #f5f0e8);
      border: 1px solid var(--color-border, #e8e2d9);
      color: var(--color-warm-black, #2a2218);
      outline: none;
      margin-bottom: 1rem;
      transition: border-color 0.2s ease;
      border-radius: 1px;
    }

    .pwd-modal-input:focus {
      border-color: var(--color-gold, #c9a96e);
    }

    .pwd-modal-input::placeholder {
      color: var(--color-text-muted, #8a7d6f);
      opacity: 0.7;
    }

    .pwd-modal-submit {
      width: 100%;
      padding: 0.9rem 1.5rem;
      font-family: var(--font-body, 'Inter', sans-serif);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: var(--color-warm-black, #2a2218);
      color: var(--color-ivory, #faf8f5);
      border: 1px solid var(--color-warm-black, #2a2218);
      cursor: pointer;
      transition: background 0.25s ease, color 0.25s ease;
      border-radius: 1px;
    }

    .pwd-modal-submit:hover {
      background: var(--color-gold, #c9a96e);
      border-color: var(--color-gold, #c9a96e);
      color: var(--color-ivory, #faf8f5);
    }

    .pwd-modal-admin {
      margin-top: 1.25rem;
      font-size: 0.75rem;
      color: var(--color-text-muted, #8a7d6f);
    }

    .pwd-modal-admin a {
      color: var(--color-gold, #c9a96e);
      text-decoration: none;
    }

    .pwd-modal-admin a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body class="template-password">

  <!-- Header -->
  <header class="pwd-header" role="banner">
    <span class="pwd-header-logo">{{ shop.name }}</span>
    <button class="pwd-header-link" id="pwd-open-modal" aria-label="Enter store password">
      {{ 'general.password_page.password_link' | t | default: 'Enter Password' }} &rarr;
    </button>
  </header>

  <!-- Main -->
  <main class="pwd-page" role="main">
    <div class="pwd-main">
      <span class="pwd-eyebrow">Lumière Silk</span>

      <h1 class="pwd-title">
        Something <em>beautiful</em><br>is on its way.
      </h1>

      <div class="pwd-divider" aria-hidden="true">
        <span class="pwd-divider-line"></span>
        <span class="pwd-divider-diamond">◆</span>
        <span class="pwd-divider-line"></span>
      </div>

      <p class="pwd-message">
        We're crafting an experience as refined as our silk. Our store opens soon — enter the password for early access.
      </p>

      <div class="pwd-content-wrap">
        {{ content_for_layout }}
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="pwd-footer">
    <p>
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. &nbsp;
      <a href="/admin" target="_blank" rel="noopener">{{ 'general.password_page.admin_link_html' | t | default: 'Admin' }}</a>
    </p>
  </footer>

  <!-- Login Modal Overlay -->
  <div class="pwd-modal-overlay" id="pwd-modal-overlay" role="dialog" aria-modal="true" aria-label="Store password">
    <div class="pwd-modal">

      <button class="pwd-modal-close" id="pwd-close-modal" aria-label="Close password modal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      <p class="pwd-modal-eyebrow">Early Access</p>
      <h2 class="pwd-modal-heading">{{ 'general.password_page.login_form_heading' | t | default: 'Enter Password' }}</h2>
      <p class="pwd-modal-sub">Use the store password to preview this experience.</p>

      {%- form 'storefront_password', id: 'PasswordLoginForm' -%}
        {%- if form.errors -%}
          <div class="pwd-modal-error" role="alert">
            {{ 'general.password_page.login_form_error' | t | default: 'Incorrect password. Please try again.' }}
          </div>
        {%- endif -%}

        <input
          type="password"
          name="password"
          id="Password"
          class="pwd-modal-input"
          placeholder="{{ 'general.password_page.login_form_password_placeholder' | t | default: 'Your password' }}"
          autocomplete="current-password"
          required
          aria-label="Store password"
        >

        <button type="submit" name="commit" class="pwd-modal-submit">
          {{ 'general.password_page.login_form_submit' | t | default: 'Enter Store' }}
        </button>
      {%- endform -%}

      <p class="pwd-modal-admin">
        Are you the store owner?
        <a href="/admin" target="_blank" rel="noopener">Log in here</a>
      </p>
    </div>
  </div>

  <script>
    (function () {
      var overlay = document.getElementById('pwd-modal-overlay');
      var openBtn = document.getElementById('pwd-open-modal');
      var closeBtn = document.getElementById('pwd-close-modal');

      function openModal() {
        overlay.classList.add('is-open');
        overlay.removeAttribute('hidden');
        document.getElementById('Password').focus();
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        overlay.classList.remove('is-open');
        document.body.style.overflow = '';
        openBtn.focus();
      }

      if (openBtn) openBtn.addEventListener('click', openModal);
      if (closeBtn) closeBtn.addEventListener('click', closeModal);

      // Close on backdrop click
      if (overlay) {
        overlay.addEventListener('click', function (e) {
          if (e.target === overlay) closeModal();
        });
      }

      // Close on Escape key
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeModal();
      });

      // Auto-open modal if there were form errors (wrong password submitted)
      {%- if form.errors -%}
        openModal();
      {%- endif -%}
    })();
  </script>

</body>
</html>
