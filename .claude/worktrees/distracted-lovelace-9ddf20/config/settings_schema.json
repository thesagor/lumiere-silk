[
  {
    "name": "theme_info",
    "theme_name": "Lumière Silk",
    "theme_version": "1.0.0",
    "theme_author": "Sagor Ahmed",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Logo & Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 60,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo max-width",
        "default": 160
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "16×16px .ico or .png recommended"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_ivory",
        "label": "Ivory (primary background)",
        "default": "#faf8f5"
      },
      {
        "type": "color",
        "id": "color_cream",
        "label": "Cream (secondary background)",
        "default": "#f5f0e8"
      },
      {
        "type": "color",
        "id": "color_blush",
        "label": "Blush (accent background)",
        "default": "#f0e8e4"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Muted Gold (brand accent)",
        "default": "#c9a96e"
      },
      {
        "type": "color",
        "id": "color_warm_black",
        "label": "Warm Black (text & buttons)",
        "default": "#2a2218"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted text",
        "default": "#8a7d6f"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#e8e2d9"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "heading_font",
        "label": "Heading font",
        "options": [
          { "value": "cormorant", "label": "Cormorant Garamond (default)" },
          { "value": "playfair", "label": "Playfair Display" }
        ],
        "default": "cormorant"
      },
      {
        "type": "range",
        "id": "body_font_size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "label": "Base font size",
        "default": 16
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "select",
        "id": "button_style",
        "label": "Primary button style",
        "options": [
          { "value": "filled", "label": "Filled" },
          { "value": "outline", "label": "Outline" }
        ],
        "default": "filled"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer (slide-in)" },
          { "value": "page", "label": "Cart page" }
        ],
        "default": "drawer"
      },
      {
        "type": "select",
        "id": "ajax_cart_method",
        "label": "Add-to-cart behaviour",
        "options": [
          { "value": "drawer", "label": "Open cart drawer" },
          { "value": "redirect", "label": "Redirect to cart page" },
          { "value": "none", "label": "No feedback (silent)" }
        ],
        "default": "drawer"
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_wishlist",
        "label": "Enable wishlist",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_quickview",
        "label": "Enable quick view",
        "default": true
      },
      {
        "type": "select",
        "id": "card_icon_alignment",
        "label": "Product icon alignment",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" }
        ],
        "default": "right"
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "animations_enabled",
        "label": "Enable scroll animations",
        "default": true
      }
    ]
  }
]
