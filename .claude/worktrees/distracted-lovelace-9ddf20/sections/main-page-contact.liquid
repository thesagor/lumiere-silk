<div class="page-banner">
  <h1 class="page-banner-title heading-serif">{{ page.title | default: 'Contact Us' }}</h1>
</div>

<div class="container">
  <div class="contact-layout">

    <!-- Contact info -->
    <div class="contact-info fade-in">
      <h2 class="contact-info-title heading-serif">We'd Love to Hear From You</h2>
      <p class="contact-info-body">
        Whether you have a question about a product, need help with an order, or simply want to say hello — we are here and happy to assist.
      </p>

      <div class="contact-detail">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <div class="contact-detail-text">
          <a href="mailto:lumieresilk.ca@gmail.com">lumieresilk.ca@gmail.com</a>
        </div>
      </div>

      <div class="contact-detail">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="contact-detail-text">
          We typically respond within 1–2 business days.
        </div>
      </div>

      <div style="margin-top:2rem; padding:1.5rem; background:var(--color-cream);">
        <p class="text-label" style="margin-bottom:0.75rem;">Returns &amp; Orders</p>
        <p style="font-size:0.9375rem; color:var(--color-text-muted); line-height:1.75;">
          For returns, exchanges, or order inquiries, please include your order number in your message and we will assist you promptly.
        </p>
      </div>
    </div>

    <!-- Contact form -->
    <div class="fade-in">
      {%- form 'contact', class: 'contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div style="padding:1.5rem; background:var(--color-cream); text-align:center; margin-bottom:1.5rem;">
            <p class="text-label" style="margin-bottom:0.5rem;">Message Sent</p>
            <p style="font-family:var(--font-heading); font-size:1.125rem;">Thank you for reaching out. We will be in touch soon.</p>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div style="padding:1rem; background:#fff0f0; border:1px solid #f5c6c6; margin-bottom:1rem; font-size:0.875rem; color:#c00;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="form-group">
          <label class="form-label" for="contact-name">Name</label>
          <input class="form-input" type="text" id="contact-name" name="contact[name]" value="{{ form.name }}" required autocomplete="name" placeholder="Your full name">
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-email">Email</label>
          <input class="form-input" type="email" id="contact-email" name="contact[email]" value="{{ form.email }}" required autocomplete="email" placeholder="your@email.com">
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-subject">Subject</label>
          <input class="form-input" type="text" id="contact-subject" name="contact[subject]" placeholder="Order inquiry, question, etc.">
        </div>

        <div class="form-group">
          <label class="form-label" for="contact-message">Message</label>
          <textarea class="form-textarea" id="contact-message" name="contact[body]" required placeholder="How can we help you?" rows="6">{{ form.body }}</textarea>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">Send Message</button>
      {%- endform -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
