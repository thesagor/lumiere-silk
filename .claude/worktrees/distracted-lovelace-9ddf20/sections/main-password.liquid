<div style="text-align:center;">
  <p style="font-family:var(--font-heading); font-style:italic; font-size:1rem; color:var(--color-text-muted); margin-bottom:2rem;">
    {{ section.settings.message | default: 'Our store is coming soon. Enter the password to get early access.' }}
  </p>

  {%- form 'storefront_password', class: 'password-form' -%}
    <input type="hidden" name="return_to" value="{{ routes.root_url }}">
    {%- if form.errors -%}
      <p style="color:#c00; font-size:0.875rem; margin-bottom:0.75rem;">Incorrect password. Please try again.</p>
    {%- endif -%}
    <div style="display:flex; flex-direction:column; gap:0.75rem; max-width:320px; margin:0 auto;">
      <input
        type="password"
        name="password"
        class="form-input"
        placeholder="Enter password"
        autocomplete="current-password"
        required
        aria-label="Store password"
      >
      <button type="submit" class="btn btn-primary" style="justify-content:center;">Enter Store</button>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "Our store is coming soon. Enter the password to get early access."
    }
  ]
}
{% endschema %}
