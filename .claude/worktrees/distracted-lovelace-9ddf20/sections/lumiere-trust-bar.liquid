{%- if section.settings.show_trust_bar -%}
  <section class="trust-bar" aria-label="Store benefits">
    <div class="container">
      <div class="trust-bar-grid">
        <div class="trust-bar-item">
          <span class="trust-bar-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span>{{ section.settings.item_1 | escape }}</span>
        </div>
        <div class="trust-bar-item">
          <span class="trust-bar-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Z" stroke="currentColor" stroke-width="1.5"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" stroke="currentColor" stroke-width="1.5"/></svg>
          </span>
          <span>{{ section.settings.item_2 | escape }}</span>
        </div>
        <div class="trust-bar-item">
          <span class="trust-bar-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          </span>
          <span>{{ section.settings.item_3 | escape }}</span>
        </div>
        <div class="trust-bar-item">
          <span class="trust-bar-icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          </span>
          <span>{{ section.settings.item_4 | escape }}</span>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Trust Bar",
  "tag": "div",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_trust_bar",
      "label": "Show trust bar",
      "default": true
    },
    {
      "type": "text",
      "id": "item_1",
      "label": "Item 1",
      "default": "Free Shipping in Canada"
    },
    {
      "type": "text",
      "id": "item_2",
      "label": "Item 2",
      "default": "Gift-Ready Packaging"
    },
    {
      "type": "text",
      "id": "item_3",
      "label": "Item 3",
      "default": "Curated Selection"
    },
    {
      "type": "text",
      "id": "item_4",
      "label": "Item 4",
      "default": "Thoughtful Gifting"
    }
  ],
  "presets": [
    {
      "name": "Trust Bar"
    }
  ]
}
{% endschema %}
