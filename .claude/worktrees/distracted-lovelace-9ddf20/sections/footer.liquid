<footer class="site-footer" role="contentinfo">

  <!-- Decorative top accent -->
  <div class="footer-top-accent">
    <span class="footer-top-line"></span>
    <span class="footer-top-diamond">◆</span>
    <span class="footer-top-line"></span>
  </div>

  <div class="container">
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <div class="footer-brand-logo">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 160 | image_tag: loading: 'lazy', alt: shop.name, style: 'filter: brightness(0) invert(1); height:30px; width:auto;' }}
          {%- else -%}
            <span class="footer-brand-name">{{ shop.name }}</span>
          {%- endif -%}
        </div>
        <p class="footer-brand-tagline">{{ section.settings.tagline }}</p>
        <p class="footer-brand-desc">{{ section.settings.brand_description }}</p>

        <!-- Social links -->
        <div class="footer-social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" class="footer-social-link" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.853 0 1.267.641 1.267 1.41 0 .858-.548 2.143-.83 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.867 3.137-4.562 0-2.385-1.714-4.052-4.163-4.052-2.835 0-4.497 2.126-4.497 4.325 0 .856.33 1.774.741 2.276a.3.3 0 0 1 .069.286c-.076.313-.244.995-.277 1.134-.044.183-.147.222-.339.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.967-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.522 0 10-4.477 10-10S17.522 2 12 2z" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="footer-social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Shop links -->
      <div class="footer-col">
        <p class="footer-col-title">Shop</p>
        <ul class="footer-links">
          {%- assign shop_menu = section.settings.shop_menu | default: linklists.footer -%}
          {%- for link in shop_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Info links -->
      <div class="footer-col">
        <p class="footer-col-title">Information</p>
        <ul class="footer-links">
          {%- assign info_menu = section.settings.info_menu | default: linklists.footer -%}
          {%- for link in info_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="footer-col">
        <p class="footer-col-title">Stay in Touch</p>
        <p class="footer-newsletter-desc">
          {{ section.settings.newsletter_text }}
        </p>
        {%- form 'customer', id: 'footer-newsletter-form', class: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer-newsletter-row">
            <input
              class="footer-newsletter-input"
              type="email"
              name="contact[email]"
              placeholder="Your email address"
              required
              aria-label="Email address"
            >
            <button type="submit" class="footer-newsletter-submit" aria-label="Subscribe">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="footer-newsletter-success">Thank you for subscribing.</p>
          {%- endif -%}
        {%- endform -%}

        <!-- Trust badges -->
        <div class="footer-trust">
          <div class="footer-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Secure checkout</span>
          </div>
          <div class="footer-trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M1 10h22" stroke="currentColor" stroke-width="1.5"/></svg>
            <span>Easy returns</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Footer bottom -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <nav class="footer-policy-links" aria-label="Policy links">
        {%- if shop.privacy_policy.url -%}
          <a href="{{ shop.privacy_policy.url }}">Privacy</a>
        {%- endif -%}
        {%- if shop.refund_policy.url -%}
          <a href="{{ shop.refund_policy.url }}">Returns</a>
        {%- endif -%}
        {%- if shop.shipping_policy.url -%}
          <a href="{{ shop.shipping_policy.url }}">Shipping</a>
        {%- endif -%}
        {%- if shop.terms_of_service.url -%}
          <a href="{{ shop.terms_of_service.url }}">Terms</a>
        {%- endif -%}
      </nav>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo (optional)"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Elegance, Softness & Refinement"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium silk scarves and gift-ready accessories, designed with elegance and softness at heart."
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "info_menu",
      "label": "Information menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter description",
      "default": "Subscribe for new arrivals, style inspiration, and exclusive offers."
    }
  ]
}
{% endschema %}
